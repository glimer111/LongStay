# PostgreSQL (локально можно использовать тот же Neon или локальный Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Секрет для JWT (обязательно в production — задайте длинную случайную строку)
# JWT_SECRET="your-random-secret-at-least-32-chars"

# Vercel Blob — для загрузки изображений на Vercel (в Storage создайте Blob store, токен подставится сам)
# BLOB_READ_WRITE_TOKEN=
