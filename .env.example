# Локально: SQLite, ничего ставить не нужно
DATABASE_URL="file:./dev.db"

# Секрет для JWT (обязательно в production)
JWT_SECRET="dev-secret-change-in-production-32chars"

# Vercel Blob — только для деплоя на Vercel (локально файлы в public/uploads)
# BLOB_READ_WRITE_TOKEN=

# Свой сервер (без Blob): каталог загрузок и URL для раздачи (см. deploy/DEPLOY-SERVER.md)
# UPLOAD_DIR=/var/www/long-stay/uploads
# UPLOAD_PUBLIC_BASE=/uploads
